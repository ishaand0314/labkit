{
  "name": "@labkit/token-cost",
  "version": "0.1.0",
  "description": "Compare token counts and USD cost for the same text across models from every lab. One view, zero setup.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
