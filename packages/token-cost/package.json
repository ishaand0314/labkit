{
  "name": "@labkit/token-cost",
  "version": "0.1.0",
  "description": "Compare token counts and USD cost for the same text across models from every lab. One view, zero setup.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "token-cost": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "keywords": [
    "llm",
    "tokens",
    "tokenizer",
    "pricing",
    "cost",
    "openai",
    "anthropic",
    "gemini",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/siddhantdas/labkit.git",
    "directory": "packages/token-cost"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --build",
    "prepublishOnly": "tsc --build"
  },
  "dependencies": {
    "@anthropic-ai/tokenizer": "^0.0.4",
    "@labkit/core": "workspace:^",
    "js-tiktoken": "^1.0.21"
  }
}
