    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc --build"
  },
  "dependencies": {
    "@anthropic-ai/tokenizer": "^0.0.4",
    "@labkit/core": "workspace:*",
    "js-tiktoken": "^1.0.21"
  }
}
